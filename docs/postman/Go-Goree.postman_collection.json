{
  "info": {
    "name": "Go Gorée - API v1",
    "description": "Collection complète des workflows Go Gorée : inscription, auth, comptes contrôleurs + reset mot de passe, demandes de résidence, données de référence (voyages/trajets/chaloupes/tarifs), plans & abonnements, billetterie (portefeuille & PayDunya), embarquement & scan, portefeuille, résidents, notifications, fraude, webhook PayDunya. Tokens et identifiants capturés automatiquement.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "root_url", "value": "http://localhost:8000" },
    { "key": "base_url", "value": "{{root_url}}/api/v1" },
    { "key": "admin_email", "value": "admin@goree.sn" },
    { "key": "admin_password", "value": "Admin@1234" },
    { "key": "client_email", "value": "client@goree.sn" },
    { "key": "client_password", "value": "Client@1234" },
    { "key": "admin_token", "value": "" },
    { "key": "client_token", "value": "" },
    { "key": "controleur_token", "value": "" },
    { "key": "controleur_email", "value": "modou.controleur@goree.sn" },
    { "key": "reset_token", "value": "" },
    { "key": "demande_id", "value": "" },
    { "key": "trajet_id", "value": "" },
    { "key": "chaloupe_id", "value": "" },
    { "key": "voyage_id", "value": "" },
    { "key": "plan_id", "value": "" },
    { "key": "billet_id", "value": "" },
    { "key": "qr_token", "value": "" },
    { "key": "embarquement_id", "value": "" },
    { "key": "notification_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Authentification",
      "item": [
        {
          "name": "Inscription (register)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const d = pm.response.json().data;",
            "pm.collectionVariables.set('client_token', d.access_token);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"prenom\": \"Nouveau\",\n  \"nom\": \"Client\",\n  \"email\": \"nouveau.client@goree.sn\",\n  \"telephone\": \"770000001\",\n  \"mot_de_passe\": \"Passer@1234\",\n  \"mot_de_passe_confirmation\": \"Passer@1234\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] }
          }
        },
        {
          "name": "Login Admin",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.collectionVariables.set('admin_token', pm.response.json().data.access_token);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"mot_de_passe\": \"{{admin_password}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Login Client",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.collectionVariables.set('client_token', pm.response.json().data.access_token);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{client_email}}\",\n  \"mot_de_passe\": \"{{client_password}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Login Contrôleur",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.collectionVariables.set('controleur_token', pm.response.json().data.access_token);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{controleur_email}}\",\n  \"mot_de_passe\": \"Controleur@1234\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Mon profil (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
          }
        },
        {
          "name": "Mot de passe oublié",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{controleur_email}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/password/forgot", "host": ["{{base_url}}"], "path": ["password", "forgot"] }
          }
        },
        {
          "name": "Réinitialiser le mot de passe",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{controleur_email}}\",\n  \"token\": \"{{reset_token}}\",\n  \"mot_de_passe\": \"Controleur@1234\",\n  \"mot_de_passe_confirmation\": \"Controleur@1234\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/password/reset", "host": ["{{base_url}}"], "path": ["password", "reset"] }
          }
        }
      ]
    },
    {
      "name": "2. Utilisateurs & Contrôleurs (admin)",
      "item": [
        {
          "name": "Lister les utilisateurs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"] }
          }
        },
        {
          "name": "Créer un contrôleur",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.collectionVariables.set('controleur_email', pm.response.json().data.email);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"prenom\": \"Modou\",\n  \"nom\": \"Fall\",\n  \"email\": \"modou.controleur@goree.sn\",\n  \"telephone\": \"770000000\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/controleurs", "host": ["{{base_url}}"], "path": ["controleurs"] }
          }
        },
        {
          "name": "Lister les contrôleurs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/controleurs", "host": ["{{base_url}}"], "path": ["controleurs"] }
          }
        }
      ]
    },
    {
      "name": "3. Demandes de résidence",
      "item": [
        {
          "name": "Soumettre une demande (client)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.collectionVariables.set('demande_id', pm.response.json().demande.id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"carte_identite\": \"CNI123456789\",\n  \"residence\": \"Gorée Centre\",\n  \"photo\": \"photo_profil.png\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/demandes-residence", "host": ["{{base_url}}"], "path": ["demandes-residence"] }
          }
        },
        {
          "name": "Lister les demandes (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/demandes-residence", "host": ["{{base_url}}"], "path": ["demandes-residence"] }
          }
        },
        {
          "name": "Valider une demande (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/demandes-residence/{{demande_id}}/valider", "host": ["{{base_url}}"], "path": ["demandes-residence", "{{demande_id}}", "valider"] }
          }
        },
        {
          "name": "Refuser une demande (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"motif_refus\": \"Justificatifs illisibles.\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/demandes-residence/{{demande_id}}/refuser", "host": ["{{base_url}}"], "path": ["demandes-residence", "{{demande_id}}", "refuser"] }
          }
        }
      ]
    },
    {
      "name": "4. Données de référence (admin en écriture)",
      "item": [
        {
          "name": "Créer un trajet",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.collectionVariables.set('trajet_id', pm.response.json().id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"jour\": \"LUNDI\",\n  \"heure_depart\": \"07:30\",\n  \"duree\": 20\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/trajets", "host": ["{{base_url}}"], "path": ["trajets"] }
          }
        },
        {
          "name": "Créer une chaloupe",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.collectionVariables.set('chaloupe_id', pm.response.json().id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"imatriculation\": \"IM-BEER-001\",\n  \"nom\": \"Beer\",\n  \"capacite\": 150\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/chaloupes", "host": ["{{base_url}}"], "path": ["chaloupes"] }
          }
        },
        {
          "name": "Créer un tarif",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"categorie\": \"RESIDENT\",\n  \"prix\": 500,\n  \"trajet_id\": \"{{trajet_id}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/tarifs", "host": ["{{base_url}}"], "path": ["tarifs"] }
          }
        },
        {
          "name": "Créer un voyage",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.collectionVariables.set('voyage_id', pm.response.json().data.id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"date_voyage\": \"2026-07-20\",\n  \"places\": 150,\n  \"places_restantes\": 150,\n  \"trajet_id\": \"{{trajet_id}}\",\n  \"chaloupe_id\": \"{{chaloupe_id}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/voyages", "host": ["{{base_url}}"], "path": ["voyages"] }
          }
        },
        {
          "name": "Lister les voyages (filtres)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const rows = pm.response.json().data;",
            "if (rows && rows.length) pm.collectionVariables.set('voyage_id', rows[0].id);"
          ] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": {
              "raw": "{{base_url}}/voyages?periode=semaine&disponibles=true",
              "host": ["{{base_url}}"],
              "path": ["voyages"],
              "query": [
                { "key": "periode", "value": "semaine", "description": "today | semaine" },
                { "key": "disponibles", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Lister les tarifs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": { "raw": "{{base_url}}/tarifs", "host": ["{{base_url}}"], "path": ["tarifs"] }
          }
        },
        {
          "name": "Modifier un voyage",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"date_voyage\": \"2026-07-21\",\n  \"places\": 120,\n  \"places_restantes\": 120,\n  \"trajet_id\": \"{{trajet_id}}\",\n  \"chaloupe_id\": \"{{chaloupe_id}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/voyages/{{voyage_id}}", "host": ["{{base_url}}"], "path": ["voyages", "{{voyage_id}}"] }
          }
        }
      ]
    },
    {
      "name": "5. Plans & Abonnements",
      "item": [
        {
          "name": "Lister les plans (public)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const rows = pm.response.json();",
            "if (rows && rows.length) pm.collectionVariables.set('plan_id', rows[0].id);"
          ] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": { "raw": "{{base_url}}/plans", "host": ["{{base_url}}"], "path": ["plans"] }
          }
        },
        {
          "name": "Créer un plan (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"nom\": \"Abonnement 1 mois\",\n  \"duree_mois\": 1,\n  \"prix\": 5000\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/plans", "host": ["{{base_url}}"], "path": ["plans"] }
          }
        },
        {
          "name": "Souscrire un abonnement (résident)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "console.log('Lien de paiement PayDunya : ' + pm.response.json().redirect_url);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"plan_id\": \"{{plan_id}}\",\n  \"payment_mode\": \"PORTEFEUILLE\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/abonnements/souscrire", "host": ["{{base_url}}"], "path": ["abonnements", "souscrire"] }
          }
        }
      ]
    },
    {
      "name": "6. Billetterie",
      "item": [
        {
          "name": "Acheter un billet - Portefeuille",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const b = pm.response.json().billet;",
            "pm.collectionVariables.set('billet_id', b.id);",
            "pm.collectionVariables.set('qr_token', b.qr_token);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"voyage_id\": \"{{voyage_id}}\",\n  \"payment_mode\": \"PORTEFEUILLE\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/billets", "host": ["{{base_url}}"], "path": ["billets"] }
          }
        },
        {
          "name": "Acheter un billet - PayDunya (lien de paiement)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const r = pm.response.json();",
            "console.log('Lien de paiement PayDunya : ' + r.redirect_url);",
            "if (r.billet) { pm.collectionVariables.set('billet_id', r.billet.id); pm.collectionVariables.set('qr_token', r.billet.qr_token); }"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"voyage_id\": \"{{voyage_id}}\",\n  \"payment_mode\": \"PAYDUNYA\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/billets", "host": ["{{base_url}}"], "path": ["billets"] }
          }
        },
        {
          "name": "Lister mes billets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": { "raw": "{{base_url}}/billets", "host": ["{{base_url}}"], "path": ["billets"] }
          }
        },
        {
          "name": "Détails d'un billet",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": { "raw": "{{base_url}}/billets/{{billet_id}}", "host": ["{{base_url}}"], "path": ["billets", "{{billet_id}}"] }
          }
        }
      ]
    },
    {
      "name": "7. Embarquement & Scan (contrôleur)",
      "item": [
        {
          "name": "Ouvrir l'embarcation",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.collectionVariables.set('embarquement_id', pm.response.json().id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{controleur_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"voyage_id\": \"{{voyage_id}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/embarquements/ouvrir", "host": ["{{base_url}}"], "path": ["embarquements", "ouvrir"] }
          }
        },
        {
          "name": "Lister les embarcations ouvertes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{controleur_token}}" }],
            "url": { "raw": "{{base_url}}/embarquements", "host": ["{{base_url}}"], "path": ["embarquements"] }
          }
        },
        {
          "name": "Scanner un billet",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{controleur_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"qr_token\": \"{{qr_token}}\",\n  \"embarquement_id\": \"{{embarquement_id}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/scans", "host": ["{{base_url}}"], "path": ["scans"] }
          }
        },
        {
          "name": "Fermer l'embarcation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{controleur_token}}" }],
            "url": { "raw": "{{base_url}}/embarquements/{{embarquement_id}}/fermer", "host": ["{{base_url}}"], "path": ["embarquements", "{{embarquement_id}}", "fermer"] }
          }
        }
      ]
    },
    {
      "name": "8. Portefeuille",
      "item": [
        {
          "name": "Voir mon portefeuille",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": { "raw": "{{base_url}}/portefeuille", "host": ["{{base_url}}"], "path": ["portefeuille"] }
          }
        },
        {
          "name": "Recharger - PayDunya (lien de paiement)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "console.log('Lien de recharge PayDunya : ' + pm.response.json().redirect_url);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"montant\": 5000,\n  \"payment_mode\": \"PAYDUNYA\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/portefeuille/recharge", "host": ["{{base_url}}"], "path": ["portefeuille", "recharge"] }
          }
        }
      ]
    },
    {
      "name": "9. Résidents & Abonnements (admin)",
      "item": [
        {
          "name": "Lister les résidents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/residents", "host": ["{{base_url}}"], "path": ["residents"] }
          }
        },
        {
          "name": "Lister les abonnements",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/abonnements", "host": ["{{base_url}}"], "path": ["abonnements"] }
          }
        }
      ]
    },
    {
      "name": "10. Notifications & Fraude",
      "item": [
        {
          "name": "Mes notifications",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const rows = pm.response.json().data;",
            "if (rows && rows.length) pm.collectionVariables.set('notification_id', rows[0].id);"
          ] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": { "raw": "{{base_url}}/notifications", "host": ["{{base_url}}"], "path": ["notifications"] }
          }
        },
        {
          "name": "Marquer une notification comme lue",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": { "raw": "{{base_url}}/notifications/{{notification_id}}", "host": ["{{base_url}}"], "path": ["notifications", "{{notification_id}}"] }
          }
        },
        {
          "name": "Supprimer une notification",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": { "raw": "{{base_url}}/notifications/{{notification_id}}", "host": ["{{base_url}}"], "path": ["notifications", "{{notification_id}}"] }
          }
        },
        {
          "name": "Alertes de fraude (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/alertes-fraude", "host": ["{{base_url}}"], "path": ["alertes-fraude"] }
          }
        }
      ]
    },
    {
      "name": "11. Webhook PayDunya (simulation mode fake)",
      "item": [
        {
          "name": "Notifier le webhook",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"data\": {\n    \"hash\": \"<SHA512_DU_SECRET>\",\n    \"status\": \"completed\",\n    \"invoice\": { \"token\": \"<PAYDUNYA_TOKEN>\" }\n  }\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{root_url}}/webhooks/paydunya", "host": ["{{root_url}}"], "path": ["webhooks", "paydunya"] }
          }
        }
      ]
    }
  ]
