APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Page front recevant le jeton de réinitialisation de mot de passe (?token=...&email=...)
PASSWORD_RESET_URL="${APP_URL}/reset-password"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=go_goree
DB_USERNAME=postgres
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Notifications temps réel : "reverb" (websockets, serveur `php artisan reverb:start`) ou "log"
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# log = écrit les emails dans storage/logs/laravel.log (dev sans SMTP)
# smtp = envoi réel : renseigner HOST/PORT/USERNAME/PASSWORD ci-dessous
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@go-goree.sn"
MAIL_FROM_NAME="Go Gorée"
# Les emails transactionnels sont mis en file d'attente : un worker doit tourner
# (php artisan queue:work) pour qu'ils soient réellement envoyés. Pour un envoi
# immédiat en dev, mettre QUEUE_CONNECTION=sync.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Go Gorée : Queues dédiées ---
QUEUE_NOTIFICATIONS=notifications
QUEUE_PAIEMENTS=paiements
QUEUE_BILLETS=billets
QUEUE_SCANS=scans
QUEUE_FRAUDE=fraude
QUEUE_RAPPORTS=rapports

# --- PayDunya ---
# driver : "fake" (simulation, aucun réseau — local/tests) ou "http" (API réelle).
# Laisser vide pour déduire automatiquement de PAYDUNYA_MODE (live => http, sinon fake).
PAYDUNYA_DRIVER=fake
# Rétro-compat : "fake" ou "live". Sert de valeur par défaut au driver ci-dessus.
PAYDUNYA_MODE=fake
# environment : "test" (endpoint sandbox PayDunya) ou "live" (production). Utilisé par le driver http.
PAYDUNYA_ENVIRONMENT=test

# Clés d'API PayDunya (tableau de bord PayDunya). Requises uniquement en driver http.
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=

# Boutique affichée sur la page de paiement.
PAYDUNYA_STORE_NAME="${APP_NAME}"
PAYDUNYA_STORE_TAGLINE="Billetterie des chaloupes de Gorée"
PAYDUNYA_STORE_PHONE=
PAYDUNYA_STORE_ADDRESS=
PAYDUNYA_STORE_WEBSITE="${APP_URL}"
PAYDUNYA_STORE_LOGO=
PAYDUNYA_CURRENCY=XOF

# URLs de callback/redirection.
PAYDUNYA_WEBHOOK_URL="${APP_URL}/webhooks/paydunya"
PAYDUNYA_RETURN_URL="${APP_URL}/paiement/retour"
PAYDUNYA_CANCEL_URL="${APP_URL}/paiement/annule"

# Sécurité du webhook : exiger la signature SHA-512 (recommandé : true).
PAYDUNYA_WEBHOOK_REQUIRE_SIGNATURE=true

# Réglages HTTP du driver réel.
PAYDUNYA_HTTP_TIMEOUT=30
PAYDUNYA_HTTP_RETRIES=2
PAYDUNYA_HTTP_RETRY_DELAY_MS=300

# Driver "fake" : auto-confirmation + secret servant à signer les IPN simulés.
PAYDUNYA_FAKE_AUTO_COMPLETE=true
PAYDUNYA_FAKE_SECRET=paydunya-fake-secret-change-me
PAYDUNYA_FAKE_CHECKOUT_BASE="${APP_URL}/paydunya/fake/checkout"

# --- Anti-fraude ---
FRAUDE_VELOCITE_MAX_TENTATIVES=5
FRAUDE_VELOCITE_FENETRE_MINUTES=10
FRAUDE_ALERTE_CRITIQUE_MAIL_IMMEDIAT=true

# --- Rapports ---
RAPPORT_JOURNALIER_HEURE=23:55
RAPPORT_JOURNALIER_DESTINATAIRES_ROLE=Admin

# --- Reverb (websockets temps réel) ---
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
# Exposées au front (Vite/React) pour Laravel Echo
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
